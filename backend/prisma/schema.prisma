generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum PublicationStatus {
  ACTIVE
  INACTIVE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  SALON
  BANK_TRANSFER
  CASH_ON_DELIVERY
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum DiscountApplyTo {
  SERVICE
  PRODUCT
  ALL
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  phone        String?
  address      String?
  avatarUrl    String?
  role         UserRole      @default(USER)
  status       UserStatus    @default(ACTIVE)
  appointments Appointment[]
  orders       Order[]
  cart         Cart?
  reviews      Review[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([role, status])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  description     String
  shortDescription String?
  procedure       String?
  beforeCare      String?
  afterCare       String?
  price           Float
  duration        Int
  imageUrl        String?
  status          PublicationStatus   @default(ACTIVE)
  featured        Boolean             @default(false)
  categoryId      String
  category        ServiceCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  staffAssignments StaffService[]
  appointmentItems AppointmentItem[]
  reviews         Review[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([categoryId, status])
}

model Staff {
  id           String            @id @default(cuid())
  name         String
  phone        String?
  email        String?           @unique
  avatarUrl    String?
  description  String?
  specialties  String?
  workingDays  String?
  workingHours String?
  status       PublicationStatus @default(ACTIVE)
  services     StaffService[]
  appointments Appointment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model StaffService {
  id        String   @id @default(cuid())
  staffId   String
  serviceId String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([serviceId])
}

model Appointment {
  id               String            @id @default(cuid())
  code             String            @unique
  userId           String
  staffId          String?
  appointmentDate  DateTime
  appointmentTime  String
  totalPrice       Float
  status           AppointmentStatus @default(PENDING)
  paymentMethod    PaymentMethod     @default(SALON)
  paymentStatus    PaymentStatus     @default(PENDING)
  customerName     String
  customerPhone    String
  customerEmail    String
  note             String?
  internalNote     String?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff            Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)
  items            AppointmentItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, appointmentDate])
  @@index([staffId, appointmentDate])
  @@index([status, appointmentDate])
}

model AppointmentItem {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  serviceName   String
  price         Float
  duration      Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([appointmentId])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  description       String
  benefits          String?
  usageInstructions String?
  price             Float
  discountPrice     Float?
  imageUrl          String?
  stock             Int               @default(0)
  status            PublicationStatus @default(ACTIVE)
  featured          Boolean           @default(false)
  categoryId        String
  category          ProductCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           Review[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([categoryId, status])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  price     Float
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([productId])
}

model Discount {
  id            String           @id @default(cuid())
  code          String           @unique
  description   String?
  type          DiscountType
  value         Float
  applyTo       DiscountApplyTo
  minOrderValue Float            @default(0)
  maxUses       Int?
  usedCount     Int              @default(0)
  startDate     DateTime
  endDate       DateTime
  status        PublicationStatus @default(ACTIVE)
  orders        Order[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([code, status])
}

model Order {
  id              String         @id @default(cuid())
  code            String         @unique
  userId          String
  discountId      String?
  receiverName    String
  receiverPhone   String
  receiverEmail   String
  receiverAddress String
  note            String?
  totalPrice      Float
  discountAmount  Float          @default(0)
  finalPrice      Float
  paymentMethod   PaymentMethod  @default(CASH_ON_DELIVERY)
  paymentStatus   PaymentStatus  @default(PENDING)
  orderStatus     OrderStatus    @default(PENDING)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  discount        Discount?      @relation(fields: [discountId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, createdAt])
  @@index([orderStatus, paymentStatus])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  productName  String
  productImage String?
  quantity     Int
  price        Float
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  serviceId String?
  productId String?
  rating    Int
  comment   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([serviceId])
  @@index([productId])
}
